# Copy to .env and fill in. Real environment variables override these.

# Required: bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:AA...

# Who may talk to the bot. Comma-separated numeric Telegram user ids.
# DM the running bot /whoami to discover yours. Gating is on the SENDER, always.
TG_ALLOWED_USERS=

# Groups the bot may operate in. Comma-separated chat ids (supergroups look
# like -1001234567890). DMs from allowed users are always permitted; leave
# this empty for DM-only.
TG_ALLOWED_CHATS=

# Default working directory Claude runs in (per-topic override with /cwd).
# Sessions are stored per-cwd, so keep this stable.
# TG_WORKDIR=/root/sepehr/xesious

# Path to the claude CLI (uses your claude.ai login — no API key).
# CLAUDE_BIN=claude

# Default permission posture for the non-interactive runs. Switch per-topic from
# Telegram with /mode (this is only the default for topics that haven't set one).
#   plan         — read-only: researches and proposes, never edits (also: /plan <task>)
#   acceptEdits  — auto-approve edits + the tools in TG_ALLOWED_TOOLS
#   auto         (default) — classifier-gated autonomy: no prompts, but destructive or
#                  irreversible calls are blocked. Tell the classifier what your
#                  infrastructure is via the "autoMode" block in
#                  ~/.claude/settings.json — note it deliberately ignores a repo's
#                  .claude/settings.json.  https://code.claude.com/docs/en/auto-mode-config
#   bypass       — no checks at all: passes --dangerously-skip-permissions
# The CLI cannot prompt you over Telegram, so it must be pre-authorized one way or another.
# TG_PERMISSION_MODE=auto

# Tools auto-approved when TG_PERMISSION_MODE is not "bypass".
# TG_ALLOWED_TOOLS=Bash,Read,Edit,Write,Glob,Grep,WebSearch,WebFetch,Agent,TodoWrite,NotebookEdit

# Default model for every topic — an alias (opus, sonnet, haiku, fable) or a full
# id (e.g. claude-opus-4-8). Empty = account default. Override per topic with
# /model; that per-topic choice is remembered.
# TG_MODEL=

# In groups, only respond when @mentioned or replied to. 1/true to enable.
# TG_REQUIRE_MENTION=0

# Max seconds a single run may take before it's killed (default 1800s).
# TG_CLAUDE_TIMEOUT_MS=1800000

# Where the (chat,topic) -> session map is stored.
# TG_STATE_FILE=./state/sessions.json

# Files: uploads land in <topic-dir>/inbox/; files Claude puts in
# <topic-dir>/outbox/ are sent back to the chat.

# System-prompt steering applied every turn via --append-system-prompt (concise,
# phone-first, Telegram-friendly formatting, ask-when-ambiguous, ignore IDE
# framing). Works at full weight even on imported sessions. Override the text
# here, or set empty to disable.
# TG_PROFILE=

# Default for interrupt mode: 1/true means a new message cancels the running
# task and starts immediately instead of queueing. Per-topic override with
# /interrupt. Default off (messages queue).
# TG_INTERRUPT=0

# Show what Claude is actually trying in the live status message (the command, the
# path, the search) inside a collapsed expandable quote, plus its reasoning. Set 0
# for the older terse labels ("Running a command") if you'd rather not have raw
# commands visible in the chat.
# TG_PROGRESS_DETAIL=1

# Icon for topics the bridge creates (currently only /import). Must be a custom-emoji
# id from Telegram's built-in "Topics" set — 📁 (the folder) is the default. Set empty
# to leave topics with the plain lettered bubble.
# TG_TOPIC_ICON=5357315181649076022

# The bot's avatar. On startup, if the bot has NO profile photo, this is set as one
# (via setMyProfilePhoto — BotFather is not involved). A bot that already has a
# photo is never touched. TG_SET_LOGO=0 disables the check entirely.
# TG_BOT_LOGO=./assets/bot-logo.jpg
# TG_SET_LOGO=1

# Same, for the photo of each group in TG_ALLOWED_CHATS (via setChatPhoto — the bot
# must be an admin with "change group info"). Tried at startup, and again whenever the
# bot is promoted to admin — it can't happen the moment the bot is added, since it has
# no rights yet and the chat isn't allowlisted yet either. Only fills in a group that
# has NO photo; it never replaces one, since a restart isn't consent to change a group
# other people are in. Use /logo group to set it on purpose. TG_SET_GROUP_LOGO=0 to
# skip the check entirely.
# TG_GROUP_LOGO=./assets/group-logo.jpg
# TG_SET_GROUP_LOGO=1

# --- Big files: local Bot API server -----------------------------------------
# The cloud Bot API lets bots fetch at most 20 MB and upload at most 50 MB. A local
# server (https://github.com/tdlib/telegram-bot-api) lifts that to no download cap
# and 2000 MB up. Point TG_API_ROOT at one and the bridge uses it for everything.
#
# READ FIRST: a bot must be logged out of the cloud API before it can bind to a
# local server, and it cannot go back for 10 minutes — so this is a standing
# choice for the deployment, not something to switch on per big file. Old file_ids
# also stop resolving. Run ./local-api.sh migrate when you mean it.
# TG_API_ROOT=http://localhost:8081

# 1/true makes ./start.sh bring the server up (Docker) before the bridge. It only
# starts the container; it never migrates the bot for you.
# TG_LOCAL_API=0
# Needed only by ./local-api.sh — get a pair at https://my.telegram.org/apps
# TG_API_ID=
# TG_API_HASH=
